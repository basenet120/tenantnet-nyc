generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum AdminRole {
  system_admin
  tenant_rep
  mgmt_rep
}

enum PostVisibility {
  public
  private
}

enum PostStatus {
  reported
  acknowledged
  fixed
  unresolved
}

enum Borough {
  manhattan
  bronx
  brooklyn
  queens
  staten_island
}

enum BuildingType {
  rent_stabilized
  market_rate
  coop
  condo
  other
}

enum RecordType {
  dob_profile
  dob_violations
  dob_complaints
  hpd_violations
  hpd_complaints
  hpd_registration
  nyc_311
  acris
  zola
  custom
}

// ─── Models ──────────────────────────────────────────────

model Building {
  id                String       @id @default(uuid())
  name              String
  address           String
  borough           Borough
  zip               String
  block             String?
  lot               String?
  bin               String?
  floors            Int
  totalUnits        Int          @map("total_units")
  yearBuilt         Int?         @map("year_built")
  buildingType      BuildingType @default(rent_stabilized) @map("building_type")
  amenities         Json         @default("[]")
  managementCompany String?      @map("management_company")
  managementPhone   String?      @map("management_phone")
  managementEmail   String?      @map("management_email")
  replyEmail        String?      @unique @map("reply_email")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  units    Unit[]
  admins   Admin[]
  sections Section[]
  posts    Post[]
  records  BuildingRecord[]

  @@map("buildings")
}

model BuildingRecord {
  id            String     @id @default(uuid())
  buildingId    String     @map("building_id")
  recordType    RecordType @map("record_type")
  url           String
  label         String
  description   String     @default("")
  autoGenerated Boolean    @default(true) @map("auto_generated")
  createdAt     DateTime   @default(now()) @map("created_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("building_records")
}

model BuildingSignup {
  id           String   @id @default(uuid())
  address      String
  borough      String?
  zip          String?
  contactName  String   @map("contact_name")
  contactEmail String   @map("contact_email")
  contactPhone String?  @map("contact_phone")
  unitCount    Int?     @map("unit_count")
  message      String?
  status       String   @default("pending")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("building_signups")
}

model Unit {
  id               String   @id @default(uuid())
  buildingId       String   @map("building_id")
  floor            Int
  letter           String
  label            String
  qrToken          String   @unique @map("qr_token")
  qrTokenCreatedAt DateTime @default(now()) @map("qr_token_created_at")
  createdAt        DateTime @default(now()) @map("created_at")

  // Tenant profile (filled on first QR scan)
  isRegistered Boolean  @default(false) @map("is_registered")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  email        String?
  username     String?  @unique
  passwordHash String?  @map("password_hash")
  phone        String?

  // Notification preferences
  notifyNewPosts     Boolean @default(true)  @map("notify_new_posts")
  notifyComments     Boolean @default(true)  @map("notify_comments")
  notifyStatusChange Boolean @default(true)  @map("notify_status_change")
  notifyBulletins    Boolean @default(true)  @map("notify_bulletins")

  building Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  sessions Session[]
  posts    Post[]
  comments Comment[]

  @@unique([buildingId, label])
  @@map("units")
}

model Admin {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                AdminRole @default(tenant_rep)
  buildingId          String?   @map("building_id")
  name                String?
  invitedBy           String?   @map("invited_by")
  autoForwardPosts    Boolean   @default(false) @map("auto_forward_posts")
  autoForwardSections Json      @default("[]") @map("auto_forward_sections")
  notifyDigest        Boolean   @default(false) @map("notify_digest")
  createdAt           DateTime  @default(now()) @map("created_at")

  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  sessions Session[]
  posts    Post[]
  comments Comment[]

  @@map("admins")
}

model Session {
  id         String   @id @default(uuid())
  unitId     String?  @map("unit_id")
  adminId    String?  @map("admin_id")
  buildingId String?  @map("building_id")
  token      String   @unique
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  unit  Unit?  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  admin Admin? @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Section {
  id               String  @id @default(uuid())
  buildingId       String  @map("building_id")
  name             String
  slug             String
  description      String  @default("")
  hasIssueTracking Boolean @default(false) @map("has_issue_tracking")
  sortOrder        Int     @default(0) @map("sort_order")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  posts    Post[]

  @@unique([buildingId, slug])
  @@map("sections")
}

model Post {
  id         String         @id @default(uuid())
  buildingId String         @map("building_id")
  sectionId  String         @map("section_id")
  unitId     String?        @map("unit_id")
  adminId    String?        @map("admin_id")
  title      String
  body       String
  isPinned   Boolean        @default(false) @map("is_pinned")
  status     PostStatus?
  visibility PostVisibility @default(public)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  building Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  section  Section   @relation(fields: [sectionId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
  admin    Admin?    @relation(fields: [adminId], references: [id])
  comments Comment[]
  images   Image[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  unitId    String?  @map("unit_id")
  adminId   String?  @map("admin_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  unit   Unit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  admin  Admin?  @relation(fields: [adminId], references: [id], onDelete: SetNull)
  images Image[]

  @@map("comments")
}

model Image {
  id        String   @id @default(uuid())
  postId    String?  @map("post_id")
  commentId String?  @map("comment_id")
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("images")
}
